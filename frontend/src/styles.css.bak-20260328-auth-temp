/* Solofleet Command Center Theme */

:root {
  /* Colors */
  --bg: #080C14;
  --surface: #0E1420;
  --surface-raised: #141B2B;
  --surface-hover: #1E273A;
  --border: rgba(255, 255, 255, 0.08);
  --border-focus: rgba(249, 115, 22, 0.4);
  
  --primary: #F97316;     /* Amber/Orange */
  --primary-glow: rgba(249, 115, 22, 0.15);
  --primary-hover: #FB923C;
  --primary-text: #FFEDD5;
  
  --danger: #EF4444;
  --danger-glow: rgba(239, 68, 68, 0.15);
  --danger-surface: rgba(239, 68, 68, 0.08);

  --warning: #F59E0B;
  --warning-glow: rgba(245, 158, 11, 0.15);
  --warning-surface: rgba(245, 158, 11, 0.08);

  --success: #22C55E;
  --success-glow: rgba(34, 197, 94, 0.15);
  --success-surface: rgba(34, 197, 94, 0.08);

  --info: #3B82F6;

  --text-main: #F1F5F9;
  --text-muted: #64748B;
  --text-dark: #FFFFFF;

  /* Typography */
  --font-body: 'Inter', sans-serif;
  --font-heading: 'Space Grotesk', sans-serif;
  --font-mono: 'Space Grotesk', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;

  /* Layout */
  --sidebar-width: 220px;
  --sidebar-collapsed-width: 64px;
  --topbar-height: 64px;
  --statusbar-height: 32px;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: var(--font-body);
  color: var(--text-main);
  background-color: var(--bg);
  /* A subtle grain pattern or radial gradient makes it premium */
  background-image: 
    radial-gradient(circle at top right, rgba(249, 115, 22, 0.04), transparent 40%),
    radial-gradient(circle at bottom left, rgba(59, 130, 246, 0.03), transparent 40%);
  background-attachment: fixed;
  overflow: hidden; /* App layout handles scrolling */
  font-size: 14px;
  -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-heading);
  margin: 0;
  color: var(--text-dark);
  letter-spacing: -0.02em;
}

button {
  font-family: inherit;
  cursor: pointer;
  border: none;
  background: none;
}

input, select, textarea {
  font-family: inherit;
  color: inherit;
  background: var(--surface-raised);
  border: 1px solid var(--border);
  padding: 8px 12px;
  border-radius: 6px;
  font-size: 13px;
  transition: all 0.2s ease;
}

input:focus, select:focus, textarea:focus {
  outline: none;
  border-color: var(--border-focus);
  box-shadow: 0 0 0 2px var(--primary-glow);
}

/* Base UI Components (Replacing HeroUI) */

.sf-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 8px 16px;
  border-radius: 6px;
  font-weight: 500;
  font-size: 13px;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1px solid transparent;
}

.sf-btn-primary {
  background: var(--primary);
  color: #fff;
  box-shadow: 0 0 12px var(--primary-glow);
}

.sf-btn-primary:hover {
  background: var(--primary-hover);
  box-shadow: 0 0 16px var(--primary-glow);
  transform: translateY(-1px);
}

.sf-btn-bordered {
  background: transparent;
  border-color: var(--border);
  color: var(--text-main);
}

.sf-btn-bordered:hover {
  background: var(--surface-raised);
  border-color: rgba(255,255,255,0.2);
}

.sf-btn-light {
  background: transparent;
  color: var(--text-muted);
}
.sf-btn-light:hover {
  color: var(--text-main);
  background: rgba(255,255,255,0.05);
}

.sf-btn-icon {
  padding: 8px;
}

.sf-chip {
  display: inline-flex;
  align-items: center;
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border: 1px solid transparent;
  white-space: nowrap;
}

.sf-chip-default { background: var(--surface-raised); border-color: var(--border); color: var(--text-muted); }
.sf-chip-primary { background: var(--primary-glow); border-color: rgba(249,115,22,0.3); color: var(--primary-text); }
.sf-chip-danger { background: var(--danger-surface); border-color: rgba(239,68,68,0.3); color: #FCA5A5; }
.sf-chip-warning { background: var(--warning-surface); border-color: rgba(245,158,11,0.3); color: #FCD34D; }
.sf-chip-success { background: var(--success-surface); border-color: rgba(34,197,94,0.3); color: #86EFAC; }
.sf-chip-info { background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.3); color: #93C5FD; }

.sf-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  display: flex;
  flex-direction: column;
}

.sf-card-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
}
.sf-card-header h2 {
  font-size: 16px;
  margin-bottom: 4px;
}
.sf-card-header p {
  color: var(--text-muted);
  font-size: 12px;
  margin: 0;
}
.sf-card-content {
  padding: 20px;
  flex: 1;
}

.sf-link {
  color: var(--primary);
  text-decoration: none;
  font-weight: 500;
}
.sf-link:hover {
  text-decoration: underline;
  color: var(--primary-hover);
}

.sf-spinner {
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255,255,255,0.2);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  display: inline-block;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* App Layout Grid */

.command-center {
  display: grid;
  grid-template-areas: 
    "topbar topbar"
    "sidebar main"
    "sidebar footer";
  grid-template-rows: var(--topbar-height) 1fr var(--statusbar-height);
  grid-template-columns: var(--sidebar-width) 1fr;
  height: 100vh;
  transition: grid-template-columns 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.command-center.sidebar-collapsed {
  grid-template-columns: var(--sidebar-collapsed-width) 1fr;
}

/* Topbar */
.topbar {
  grid-area: topbar;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 0 24px;
  z-index: 10;
}

.topbar-brand {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
.brand-lockup {
  display: inline-flex;
  align-items: center;
  gap: 12px;
}
.brand-lockup-compact {
  gap: 10px;
}
.brand-mark {
  padding: 8px 14px;
  border-radius: 14px;
  border: 1px solid rgba(135, 182, 255, 0.2);
  background: linear-gradient(135deg, rgba(255,255,255,0.16), rgba(45,91,255,0.18));
  color: #DDEBFF;
  font-family: var(--font-heading);
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  line-height: 1;
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.08);
}
.brand-lockup-compact .brand-mark {
  padding: 7px 12px;
}
.brand-cross {
  color: var(--text-muted);
  font-family: var(--font-mono);
  font-size: 14px;
  text-transform: uppercase;
}
.brand-wordmark {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 20px;
  letter-spacing: -0.02em;
  color: var(--text-dark);
  line-height: 1;
}
.brand-lockup-compact .brand-wordmark {
  font-size: 18px;
}
.brand-wordmark span {
  color: var(--primary);
}

.topbar-controls {
  display: flex;
  align-items: center;
  gap: 16px;
  flex: 1;
  max-width: 600px;
  margin: 0 32px;
}
.date-range-group {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--surface-raised);
  padding: 4px 8px;
  border-radius: 6px;
  border: 1px solid var(--border);
}
.date-range-group input {
  background: transparent;
  border: none;
  padding: 4px;
  color: var(--text-main);
  font-family: var(--font-mono);
  font-size: 12px;
}
.search-box {
  flex: 1;
  position: relative;
}
.search-icon {
  position: absolute;
  left: 10px;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
}
.search-box input {
  width: 100%;
  padding-left: 36px;
  background: var(--surface-raised);
}

.topbar-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: flex-end;
}
.account-badge {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  background: var(--surface-raised);
  border-radius: 20px;
  border: 1px solid var(--border);
  font-size: 12px;
  font-weight: 500;
}
.account-badge span { color: var(--text-muted); }
.account-badge strong { color: var(--text-main); }

/* Left Sidebar */
.sidebar {
  grid-area: sidebar;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  padding: 16px 0;
  z-index: 5;
  overflow: hidden;
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding: 0 12px;
  flex: 1;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 10px 12px;
  border-radius: 8px;
  color: var(--text-muted);
  text-decoration: none;
  font-weight: 500;
  font-size: 14px;
  transition: all 0.2s;
  white-space: nowrap;
}

.nav-item:hover {
  background: var(--surface-raised);
  color: var(--text-main);
}

.nav-item.active {
  background: var(--primary-glow);
  color: var(--primary-text);
  box-shadow: inset 2px 0 0 var(--primary);
}

.nav-item svg {
  flex-shrink: 0;
}

.sidebar-bottom {
  padding: 12px;
  display: flex;
  border-top: 1px solid var(--border);
  justify-content: center;
}
.collapse-btn {
  width: 100%;
  justify-content: center;
  color: var(--text-muted);
}
.sidebar-collapsed .collapse-btn {
  padding: 8px 0;
}
.sidebar-collapsed .nav-item span {
  display: none;
  opacity: 0;
}
.sidebar-collapsed .nav-item {
  justify-content: center;
  padding: 12px;
}

/* Main Workspace */
.workspace {
  grid-area: main;
  overflow-y: auto;
  padding: 24px 32px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  position: relative;
}

/* Glowing Stat Strip */
.stat-strip {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 16px;
}

.stat-card {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  position: relative;
  overflow: hidden;
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--border);
  transition: background 0.3s;
}

.stat-card:hover::before {
  background: var(--primary);
  box-shadow: 0 0 10px var(--primary-glow);
}

.stat-card-danger::before { background: var(--danger); box-shadow: 0 0 10px var(--danger-glow); }
.stat-card-warning::before { background: var(--warning); box-shadow: 0 0 10px var(--warning-glow); }

.stat-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-muted);
  margin-bottom: 8px;
  display: block;
}

.stat-value {
  font-family: var(--font-heading);
  font-size: 32px;
  font-weight: 700;
  color: var(--text-dark);
  line-height: 1;
  margin-bottom: 4px;
}

.stat-note {
  font-size: 12px;
  color: var(--text-muted);
}

/* Quick Filter Pills */
.filter-strip {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  padding-bottom: 4px;
}

.filter-pill {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 20px;
  font-size: 13px;
  color: var(--text-muted);
  white-space: nowrap;
  transition: all 0.2s;
}

.filter-pill:hover {
  background: var(--surface-raised);
  color: var(--text-main);
}

.filter-pill.active {
  background: var(--primary-glow);
  border-color: rgba(249,115,22,0.4);
  color: var(--primary-text);
  box-shadow: 0 0 15px rgba(249,115,22,0.1);
}

.filter-badge {
  background: rgba(255,255,255,0.1);
  padding: 2px 6px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 600;
  font-family: var(--font-mono);
}
.filter-pill.active .filter-badge {
  background: var(--primary);
  color: #000;
}

/* Data Table */
.table-container {
  width: 100%;
  overflow-x: auto;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  text-align: left;
}

.data-table th {
  padding: 12px 16px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  background: var(--surface);
  z-index: 2;
}

.data-table td {
  padding: 12px 16px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  vertical-align: top;
}

.data-row {
  transition: background 0.2s, transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  cursor: pointer;
  animation: slideIn 0.3s forwards ease-out;
  opacity: 0;
  transform: translateX(10px);
}
@keyframes slideIn {
  to { opacity: 1; transform: translateX(0); }
}

/* Stagger animation for rows */
.data-row:nth-child(1) { animation-delay: 0.05s; }
.data-row:nth-child(2) { animation-delay: 0.1s; }
.data-row:nth-child(3) { animation-delay: 0.15s; }
.data-row:nth-child(4) { animation-delay: 0.2s; }
.data-row:nth-child(5) { animation-delay: 0.25s; }

.data-row:hover {
  background: var(--surface-hover);
}

.data-row::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 3px;
  background: transparent;
  transition: background 0.2s;
}

.data-row:hover::before {
  background: rgba(255,255,255,0.2);
}

/* Status variants for rows (Color coded left border) */
.data-row-danger::before { background: var(--danger) !important; box-shadow: 2px 0 8px var(--danger-glow); }
.data-row-warning::before { background: var(--warning) !important; box-shadow: 2px 0 8px var(--warning-glow); }

/* Table specific typography */
.cell-primary {
  font-weight: 600;
  color: var(--text-dark);
}
.cell-sub {
  color: var(--text-muted);
  font-size: 12px;
  margin-top: 4px;
}
.cell-mono {
  font-family: var(--font-mono);
}

/* Chart Container */
.chart-container {
  padding: 16px;
  background: var(--surface-raised);
  border-radius: 8px;
  border: 1px solid var(--border);
  position: relative;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}
.chart-header h3 {
  font-size: 14px;
  margin: 0;
}
.chart-legend {
  display: flex;
  gap: 16px;
  font-size: 12px;
  color: var(--text-muted);
}
.legend-item { display: flex; align-items: center; gap: 6px; }
.legend-dot { width: 8px; height: 8px; border-radius: 50%; }
.dot-t1 { background: #3B82F6; box-shadow: 0 0 6px rgba(59,130,246,0.5); }
.dot-t2 { background: #10B981; box-shadow: 0 0 6px rgba(16,185,129,0.5); }

/* Status Bar */
.status-bar {
  grid-area: footer;
  background: var(--surface-raised);
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  font-size: 12px;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

.status-left, .status-right {
  display: flex;
  align-items: center;
  gap: 16px;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 6px;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--text-muted);
}
.status-dot.active {
  background: var(--success);
  box-shadow: 0 0 8px var(--success-glow);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

/* Toasts (Replaces Banners) */
.toast-container {
  position: fixed;
  bottom: 40px;
  right: 24px;
  display: flex;
  flex-direction: column;
  gap: 12px;
  z-index: 50;
  pointer-events: none;
}

.toast {
  pointer-events: auto;
  background: var(--surface-raised);
  border: 1px solid var(--border);
  padding: 12px 16px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  gap: 12px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  animation: slideUp 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  max-width: 400px;
  font-size: 13px;
}

@keyframes slideUp {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.toast-success { border-left: 3px solid var(--success); }
.toast-error { border-left: 3px solid var(--danger); color: #FCA5A5;}
.toast-info { border-left: 3px solid var(--info); }

/* Login Shell */
.login-shell {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  background-image: 
    radial-gradient(circle at center, rgba(249, 115, 22, 0.05), transparent 50%),
    url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}

.login-card {
  width: 100%;
  max-width: 440px;
  background: rgba(14, 20, 32, 0.8);
  backdrop-filter: blur(16px);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 32px;
  box-shadow: 0 24px 64px rgba(0,0,0,0.6);
}

.login-header {
  text-align: center;
  margin-bottom: 32px;
}
.login-header h1 {
  font-size: 24px;
  margin: 16px 0 8px;
}
.login-header p {
  color: var(--text-muted);
  font-size: 14px;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 16px;
}
.field span {
  font-size: 12px;
  color: var(--text-muted);
  font-weight: 500;
}
.checkbox-field {
  flex-direction: row;
  align-items: center;
}
.checkbox-field input {
  width: auto;
}

.form-grid {
  display: grid;
  gap: 16px;
}
.split-panels {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

/* Empty State */
.empty-state {
  padding: 32px;
  text-align: center;
  color: var(--text-muted);
  border: 1px dashed var(--border);
  border-radius: 8px;
  background: rgba(255,255,255,0.02);
}

/* Detail Panel / Fleet Focus */
.fleet-focus-card {
  border-top: 3px solid var(--primary);
}
.unit-summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 12px;
  margin-top: 20px;
  margin-bottom: 24px;
}
.mini-metric {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  padding: 12px;
  border-radius: 6px;
}
.mini-metric span {
  display: block;
  font-size: 11px;
  color: var(--text-muted);
  text-transform: uppercase;
  margin-bottom: 4px;
}
.mini-metric strong {
  font-size: 18px;
  color: var(--text-main);
  font-family: var(--font-mono);
}
.mini-metric-danger {
  border-color: rgba(239,68,68,0.3);
  background: var(--danger-surface);
}
.mini-metric-danger strong { color: #FCA5A5; }

/* Utilities */
.subtle-line {
  color: var(--text-muted);
  font-size: 12px;
  margin-top: 2px;
}
.spacer-16 { height: 16px; }
.inline-buttons { display: flex; gap: 8px; flex-wrap: wrap; }
.chip-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px; }

/* Account Stack (Config) */
.account-stack { display: flex; flex-direction: column; gap: 12px; }
.account-item {
  background: var(--surface-raised);
  border: 1px solid var(--border);
  padding: 16px;
  border-radius: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.account-item-active {
  border-color: rgba(249,115,22,0.4);
  box-shadow: inset 0 0 0 1px rgba(249,115,22,0.2);
}


.panel-container {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.control-inline-actions {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.brand-lockup-login-shell {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.brand-lockup-login-shell .brand-lockup {
  flex-shrink: 0;
}

.table-shell {
  width: 100%;
  overflow-x: auto;
}

.metric-strip {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 12px;
}

.fleet-inline-table th,
.fleet-inline-table td {
  white-space: nowrap;
}

.fleet-inline-table th {
  padding: 10px 12px;
}

.fleet-inline-table td {
  padding: 10px 12px;
}

.fleet-inline-table .sf-btn {
  padding: 6px 10px;
  font-size: 12px;
}

.fleet-table-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
  color: var(--text-muted);
  font-size: 12px;
}

.data-row-active {
  background: rgba(249,115,22,0.08);
}

.data-row-active::before {
  background: var(--primary) !important;
  box-shadow: 2px 0 10px rgba(249,115,22,0.35);
}


.fleet-inline-table td:nth-child(6),
.fleet-inline-table td:nth-child(11),
.fleet-inline-table td:nth-child(12),
.fleet-inline-table td:nth-child(13) {
  white-space: normal;
}

.fleet-row-actions {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 8px;
  min-width: 132px;
}

.fleet-row-button {
  width: 100%;
}

.fleet-expand-row td {
  padding: 0;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  background: rgba(10, 16, 28, 0.72);
}

.fleet-expand-shell {
  padding: 18px 20px 20px;
}

.fleet-expand-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
  margin-bottom: 16px;
}

.historical-toolbar {
  display: grid;
  grid-template-columns: minmax(220px, 1.3fr) minmax(220px, 1fr) repeat(2, minmax(160px, 0.6fr));
  gap: 16px;
  margin-bottom: 20px;
}

.historical-field {
  margin-bottom: 0;
}

.historical-summary {
  margin-bottom: 16px;
  color: var(--text-muted);
  font-size: 12px;
}

.historical-search-box input {
  width: 100%;
}
@media (max-width: 1200px) {
  .topbar {
    align-items: flex-start;
    padding: 12px 20px;
  }

  .topbar-controls {
    margin: 0;
    max-width: none;
  }

  .fleet-expand-head {
    flex-direction: column;
  }

  .historical-toolbar {
    grid-template-columns: 1fr;
  }

  .fleet-table-summary {
    flex-direction: column;
    align-items: flex-start;
  }

  .fleet-row-actions {
    min-width: 0;
  }
}

@media (max-width: 960px) {
  body {
    overflow: auto;
  }

  .command-center {
    grid-template-areas:
      "topbar"
      "main"
      "footer";
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr auto;
    height: auto;
    min-height: 100vh;
  }

  .sidebar {
    display: none;
  }

  .topbar {
    flex-direction: column;
    align-items: stretch;
  }

  .topbar-controls {
    flex-direction: column;
  }

  .topbar-actions {
    justify-content: flex-start;
  }

  .workspace {
    padding: 20px;
  }

  .split-panels {
    grid-template-columns: 1fr;
  }

  .status-bar {
    flex-direction: column;
    gap: 8px;
    padding: 12px 20px;
  }

  .status-left,
  .status-right {
    width: 100%;
    justify-content: space-between;
    flex-wrap: wrap;
  }
}
