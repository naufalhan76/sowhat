# Copy this file to `.env.local` and edit values for your local dev box.
# `.env.local` is gitignored, never commit real secrets.

# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── PostgreSQL ───────────────────────────────────────────
# Default local Docker setup (matches the `sowhat-pg` container in this repo):
#   docker run --name sowhat-pg -e POSTGRES_PASSWORD=devintest \
#     -e POSTGRES_DB=sowhat -p 5432:5432 -d postgres:16
DATABASE_URL=postgres://postgres:devintest@localhost:5432/sowhat
# Optional tuning (defaults shown)
POSTGRES_CONNECT_TIMEOUT_MS=5000
POSTGRES_QUERY_TIMEOUT_MS=8000

# ─── Web auth (login form di /) ───────────────────────────
# Server seeds an admin user on first boot using these creds.
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=devintest
# Used to sign session cookies. Generate via: openssl rand -hex 32
WEB_SESSION_SECRET=dev-session-secret-change-me
# Set to false for HTTP localhost dev (default in dev). Set true in prod.
COOKIE_SECURE=false

# ─── Rate limiting (defaults shown) ───────────────────────
LOGIN_RATE_LIMIT_WINDOW_MS=900000
WEB_LOGIN_RATE_LIMIT_MAX=10
SOLOFLEET_LOGIN_RATE_LIMIT_MAX=8

# ─── Solofleet / TMS ──────────────────────────────────────
# Solofleet API timezone offset in minutes (default = UTC+7 = 420)
SOLOFLEET_UTC_OFFSET_MINUTES=420
# CargoShare TMS upstream timeout
TMS_REQUEST_TIMEOUT_MS=20000
